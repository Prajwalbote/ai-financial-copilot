# ============================================================
# .env.example — Environment Variables Template
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your values.
# NEVER commit .env to git. It contains secrets!
# .env is already listed in .gitignore.
#
# This file (.env.example) IS safe to commit — it shows
# teammates what variables they need without revealing values.

# --- HuggingFace ---
# Get your token at: https://huggingface.co/settings/tokens
# Needed to download gated models (e.g., Llama)
# For public models like Flan-T5, this is optional
HUGGINGFACE_TOKEN=your_token_here

# --- Application ---
ENVIRONMENT=development   # development | staging | production
DEBUG=true

# --- API Security (for production) ---
# API_SECRET_KEY=generate_a_random_64_char_string_here
# Uncomment above for production deployments

# --- Optional: Financial Data APIs ---
# Alpha Vantage: Free tier available at alphavantage.co
# ALPHA_VANTAGE_API_KEY=your_key_here
# We'll primarily use yfinance (free, no key needed)
