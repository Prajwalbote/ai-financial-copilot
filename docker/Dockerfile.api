# ── Dockerfile.api — FastAPI Backend Container ──────────────
# 
# WHY python:3.11-slim?
# - slim = minimal base image (~50MB vs ~900MB for full)
# - Smaller image = faster deployment, less attack surface
# - 3.11 = good performance improvements over 3.10
#
FROM python:3.11-slim

# Set working directory inside container
WORKDIR /app

# WHY COPY requirements FIRST?
# Docker builds in layers. If requirements.txt doesn't change,
# Docker reuses the cached pip install layer.
# This makes rebuilds MUCH faster.
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Create necessary directories
RUN mkdir -p data/raw data/processed data/embeddings \
    data/vectordb data/models logs

# Expose the API port
EXPOSE 8000

# Health check — Docker will restart container if this fails
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s \
    CMD curl -f http://localhost:8000/health || exit 1

# Run the API server
# --workers 2: Handle 2 requests simultaneously
# --host 0.0.0.0: Accept connections from outside container
CMD ["uvicorn", "api.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--workers", "2"]